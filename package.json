{
  "name": "ftc-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets AI agents build, deploy, and debug FTC robot code (FtcRobotController SDK + Pedro Pathing)",
  "type": "module",
  "bin": {
    "ftc-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "setup": "node dist/index.js setup",
    "test": "npm run build && node scripts/test-client.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ftc",
    "robotics",
    "first-tech-challenge",
    "pedro-pathing",
    "ftclib",
    "android"
  ],
  "author": "Sanjit K.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sanjit-K/ftc-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Sanjit-K/ftc-mcp/issues"
  },
  "homepage": "https://github.com/Sanjit-K/ftc-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
