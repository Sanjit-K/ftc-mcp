{
  "name": "ftc-toolchain",
  "version": "0.3.0",
  "description": "MCP server for Codex, Claude, and other AI agents to build, deploy, and debug FTC robot code",
  "type": "module",
  "bin": {
    "ftc-toolchain": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "studio-dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "setup": "node dist/index.js setup",
    "test": "npm run build && node scripts/test-client.mjs && node scripts/test-auto-import.mjs && node scripts/test-studio.mjs",
    "studio:build": "npm --prefix website run studio:build && node scripts/copy-studio-build.mjs",
    "prepublishOnly": "npm run build && npm run studio:build"
  },
  "keywords": [
    "ftc-toolchain",
    "mcp",
    "model-context-protocol",
    "ftc",
    "robotics",
    "first-tech-challenge",
    "pedro-pathing",
    "ftclib",
    "android"
  ],
  "author": "Sanjit K.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sanjit-K/ftc-toolchain.git"
  },
  "bugs": {
    "url": "https://github.com/Sanjit-K/ftc-toolchain/issues"
  },
  "homepage": "https://github.com/Sanjit-K/ftc-toolchain#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
